<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Certificado — {{recipient_name}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background: #fdf8f0;
      width: 960px;
      height: 680px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .certificate {
      width: 860px;
      border: 12px double #b8860b;
      padding: 50px 70px;
      text-align: center;
      position: relative;
      background: #fffef9;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
    }

    .corner {
      position: absolute;
      width: 48px;
      height: 48px;
      border-color: #b8860b;
      border-style: solid;
    }
    .corner-tl { top: 10px; left: 10px; border-width: 3px 0 0 3px; }
    .corner-tr { top: 10px; right: 10px; border-width: 3px 3px 0 0; }
    .corner-bl { bottom: 10px; left: 10px; border-width: 0 0 3px 3px; }
    .corner-br { bottom: 10px; right: 10px; border-width: 0 3px 3px 0; }

    .org-name { font-size: 13px; text-transform: uppercase; letter-spacing: 4px; color: #8b6914; margin-bottom: 8px; }
    .cert-title { font-size: 40px; color: #2c1810; margin-bottom: 4px; font-style: italic; }
    .cert-sub   { font-size: 13px; text-transform: uppercase; letter-spacing: 3px; color: #8b6914; margin-bottom: 32px; }

    .divider-gold { width: 200px; height: 2px; background: linear-gradient(to right, transparent, #b8860b, transparent); margin: 0 auto 32px; }

    .presents { font-size: 14px; color: #666; margin-bottom: 12px; }
    .recipient { font-size: 36px; color: #1a0a00; font-style: italic; border-bottom: 1px solid #b8860b; display: inline-block; padding-bottom: 4px; margin-bottom: 24px; }

    .achievement { font-size: 14px; color: #444; line-height: 1.8; margin-bottom: 8px; }
    .course-name { font-size: 20px; font-weight: bold; color: #2c1810; margin-bottom: 24px; }

    .details { display: flex; justify-content: center; gap: 40px; margin: 28px 0; font-size: 12px; color: #888; }
    .details span strong { display: block; font-size: 14px; color: #333; }

    .signatures { display: flex; justify-content: space-around; margin-top: 40px; }
    .sig-block { text-align: center; }
    .sig-line { width: 160px; border-top: 1px solid #333; margin: 0 auto 6px; }
    .sig-name  { font-size: 13px; font-weight: bold; color: #1a0a00; }
    .sig-role  { font-size: 11px; color: #888; }

    .seal { position: absolute; bottom: 50px; right: 70px; width: 80px; height: 80px; border-radius: 50%; border: 4px solid #b8860b; display: flex; align-items: center; justify-content: center; font-size: 9px; text-align: center; color: #b8860b; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; line-height: 1.3; }
  </style>
</head>
<body>
  <div class="certificate">
    <div class="corner corner-tl"></div>
    <div class="corner corner-tr"></div>
    <div class="corner corner-bl"></div>
    <div class="corner corner-br"></div>

    <div class="org-name">{{organization}}</div>
    <div class="cert-title">Certificado</div>
    <div class="cert-sub">de {{certificate_type}}</div>

    <div class="divider-gold"></div>

    <div class="presents">Se otorga el presente certificado a</div>
    <div class="recipient">{{recipient_name}}</div>

    <div class="achievement">Por haber completado satisfactoriamente</div>
    <div class="course-name">{{course_or_achievement}}</div>

    {{#if description}}
    <p style="font-size:13px;color:#666;margin-bottom:20px;">{{description}}</p>
    {{/if}}

    <div class="details">
      <span><strong>{{hours}}</strong> Horas académicas</span>
      <span><strong>{{issue_date}}</strong> Fecha de emisión</span>
      <span><strong>{{certificate_id}}</strong> N° Certificado</span>
    </div>

    <div class="signatures">
      {{#each signatories}}
      <div class="sig-block">
        <div class="sig-line"></div>
        <div class="sig-name">{{name}}</div>
        <div class="sig-role">{{role}}</div>
      </div>
      {{/each}}
    </div>

    <div class="seal">Doc<br/>Engine<br/>X</div>
  </div>
</body>
</html>
